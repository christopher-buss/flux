{
	"extends": "@isentinel/tsconfig/roblox",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "${configDir}/tsconfig.tsbuildinfo",
		"target": "esnext",
		"module": "preserve",
		"moduleResolution": "bundler",
		"typeRoots": ["${configDir}/node_modules/@rbxts", "${configDir}/node_modules/@flux"],
		"types": ["compiler-types", "jest-extended"],
		"downlevelIteration": null,
		"sourceMap": true
	},
	"references": [
		{
			"path": "e2e/default"
		},
		{
			"path": "e2e/jecs"
		},
		{
			"path": "e2e/react"
		},
		{
			"path": "e2e/server-authority"
		},
		{
			"path": "packages/core"
		},
		{
			"path": "packages/jecs"
		},
		{
			"path": "packages/react"
		},
		{
			"path": "packages/test-utils"
		},
		{
			"path": "scripts"
		},
		{
			"path": "tsconfig.node.json"
		}
	],
	"files": [],
	"include": []
}
