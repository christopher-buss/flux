{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"tsBuildInfoFile": "out/tsconfig.tsbuildinfo",
		"customConditions": ["source"],
		"declaration": true,
		"outDir": "out"
	},
	"include": ["src/**/*.ts", "../../types/**/*.d.ts"],
	"exclude": [
		"node_modules",
		"out",
		"**/.*/",
		"dist",
		"test",
		"src/**/*.spec.ts",
		"src/**/*.spec-d.ts"
	]
}
