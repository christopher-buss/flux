{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"tsBuildInfoFile": "out-test/tsconfig.tsbuildinfo",
		"rootDir": null,
		"rootDirs": ["src", "test"],
		"customConditions": ["source"],
		"outDir": "out-test"
	},
	"references": [
		{
			"path": "../test-utils"
		},
		{
			"path": "tsconfig.lib.json"
		},
		{
			"path": "../test-utils/tsconfig.lib.json"
		},
		{
			"path": "../core/tsconfig.lib.json"
		}
	],
	"include": ["src/**/*.spec.ts", "test/**/*", "../../types/**/*.d.ts"],
	"exclude": ["node_modules", "out", "out-test", "**/.*/", "dist"]
}
