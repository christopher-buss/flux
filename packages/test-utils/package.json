{
	"name": "@flux/test-utils",
	"version": "0.1.0",
	"private": true,
	"description": "Shared test utilities for Flux",
	"keywords": [
		"roblox",
		"rbxts",
		"test"
	],
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"import": "./out/init.luau",
			"types": "./src/index.ts"
		},
		"./loaders/*": "./loaders/*",
		"./out/*": "./out/*"
	},
	"main": "./dist/init.luau",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "rbxtsc --project tsconfig.lib.json",
		"clean": "rimraf .jest-roblox-coverage/ out/ out-test/ dist/",
		"dev:build": "rbxtsc --build --type=game --rojo test.project.json --project tsconfig.spec.json",
		"test": "pnpm dev:build && jest-roblox"
	},
	"devDependencies": {
		"@isentinel/jest-roblox": "catalog:test",
		"@isentinel/roblox-ts": "catalog:build",
		"@isentinel/tsconfig": "catalog:tsc",
		"@rbxts/compiler-types": "catalog:types",
		"@rbxts/jest-extended": "catalog:test",
		"@rbxts/jest-globals": "catalog:test",
		"@rbxts/jest-utils": "catalog:test",
		"@rbxts/react-roblox-fire": "catalog:test",
		"@rbxts/types": "catalog:types",
		"rimraf": "catalog:node",
		"typescript": "catalog:tsc"
	}
}
