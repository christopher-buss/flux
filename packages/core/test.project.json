{
	"name": "test",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"flux": {
				"$path": "out"
			},
			"jest.config": {
				"$path": "jest.config.luau"
			},
			"rbxts_include": {
				"$path": "test/include",
				"node_modules": {
					"$className": "Folder",
					"@rbxts": {
						"$path": "../../rojo-sync/@rbxts"
					},
					"@rbxts-js": {
						"$path": "../../rojo-sync/@rbxts-js"
					}
				}
			}
		}
	}
}
