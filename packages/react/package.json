{
	"name": "@rbxts/flux-react",
	"version": "0.1.0",
	"description": "React wrapper for Flux input system",
	"keywords": [
		"roblox",
		"input",
		"rbxts",
		"react"
	],
	"homepage": "https://github.com/christopher-buss/flux/",
	"bugs": {
		"url": "https://github.com/christopher-buss/flux/issues"
	},
	"repository": {
		"url": "https://github.com/christopher-buss/flux/",
		"type": "git"
	},
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"imports": {
		"#src/*": {
			"source": [
				"./src/*.ts",
				"./src/*.tsx"
			]
		},
		"#test/fixtures": {
			"source": "./test/fixtures.ts"
		},
		"#test/probes": {
			"source": "./test/probes.tsx"
		}
	},
	"exports": {
		".": {
			"source": "./src/index.ts",
			"import": "./dist/init.luau",
			"types": "./dist/index.d.ts"
		}
	},
	"main": "./dist/init.luau",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"!**/*tsconfig.tsbuildinfo"
	],
	"scripts": {
		"build": "rbxtsc --project tsconfig.lib.json",
		"clean": "rimraf .jest-roblox/ out/ out-test/ dist/",
		"dev:build": "rbxtsc --build --type=game --project tsconfig.spec.json",
		"test": "jest-roblox",
		"typecheck": "tsgo --noEmit",
		"typecheck:types": "tsgo --project tsconfig.typetest.json --noEmit"
	},
	"devDependencies": {
		"@flux/test-utils": "workspace:*",
		"@isentinel/jest-roblox": "catalog:test",
		"@isentinel/roblox-ts": "catalog:build",
		"@isentinel/tsconfig": "catalog:tsc",
		"@rbxts-js/dom-testing-library-lua": "catalog:test",
		"@rbxts-js/react-testing-library-lua": "catalog:test",
		"@rbxts/compiler-types": "catalog:types",
		"@rbxts/flux": "workspace:*",
		"@rbxts/jest": "catalog:test",
		"@rbxts/jest-extended": "catalog:test",
		"@rbxts/jest-globals": "catalog:test",
		"@rbxts/jest-utils": "catalog:test",
		"@rbxts/react": "catalog:peer",
		"@rbxts/react-roblox": "catalog:peer",
		"@rbxts/react-roblox-fire": "catalog:test",
		"@rbxts/regexp": "catalog:test",
		"@rbxts/types": "catalog:types",
		"@typescript/native-preview": "catalog:tsc",
		"rimraf": "catalog:node",
		"type-fest": "catalog:types",
		"typescript": "catalog:tsc"
	},
	"peerDependencies": {
		"@rbxts/flux": "workspace:*",
		"@rbxts/react": "catalog:peer",
		"@rbxts/react-roblox": "catalog:peer"
	},
	"packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85",
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
