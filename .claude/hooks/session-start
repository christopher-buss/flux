#!/usr/bin/env bash
# SessionStart hook for local skills

set -euo pipefail

# Clean stale TDD state entries (>6 hours)
STATE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)/state"
mkdir -p "$STATE_DIR"
STATE_FILE="${STATE_DIR}/tdd.json"
if [ -f "$STATE_FILE" ]; then
  NOW=$(date +%s)
  CUTOFF=$((NOW - 21600))
  jq --arg cutoff "$CUTOFF" 'with_entries(select(.value > ($cutoff | tonumber)))' "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
fi

# Determine plugin root directory
PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../.." && pwd)}"

# Read using-skills content
using_skills_content=$(cat "${PROJECT_ROOT}/.claude/skills/using-skills/SKILL.md" 2>&1 || echo "Error reading using-skills skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_skills_escaped=$(escape_for_json "$using_skills_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have skills that significantly expand your capabilities.\n\n**Below is the full content of your 'using-skills' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_skills_escaped}\n\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

printf "\n[SessionStart Hook] Injected using-skills content into session context.\n" >&2

exit 0