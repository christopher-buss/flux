{
	"name": "flux",
	"version": "0.1.0",
	"private": true,
	"description": "Input Action System wrapper for Roblox",
	"keywords": [
		"roblox",
		"input"
	],
	"license": "MIT",
	"author": "Christopher Buss <christopher.buss@pm.me> (https://github.com/christopher-buss)",
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"clean": "turbo run clean && rimraf .jest-roblox/",
		"dev:build": "rbxtsc --build tsconfig.build.json --type=game",
		"eslint-config": "npx @eslint/config-inspector",
		"postinstall": "node scripts/generate-rojo-node-modules.ts",
		"lint": "node scripts/lint.ts",
		"lint:ci": "eslint --cache --cache-strategy content",
		"test": "FORCE_COLOR=1 turbo run dev:build && jest-roblox --workspace --packages @rbxts/flux,@rbxts/flux-jecs,@rbxts/flux-react,@flux/test-utils",
		"test:affected": "FORCE_COLOR=1 turbo run dev:build && jest-roblox --workspace --affected-since=${BASE_REF:-main}",
		"test:scripts": "pnpm --filter scripts test",
		"typecheck": "tsgo --build --emitDeclarationOnly"
	},
	"devDependencies": {
		"@eslint/config-inspector": "catalog:lint",
		"@isentinel/eslint-config": "catalog:lint",
		"@isentinel/hooks": "catalog:lint",
		"@isentinel/jest-roblox": "catalog:test",
		"@isentinel/roblox-ts": "catalog:build",
		"@isentinel/tsconfig": "catalog:tsc",
		"@roblox-ts/rojo-resolver": "catalog:test",
		"@types/node": "catalog:types",
		"@typescript/native-preview": "catalog:tsc",
		"eslint": "catalog:lint",
		"eslint-plugin-jest": "catalog:lint",
		"eslint-plugin-jest-extended": "catalog:lint",
		"eslint-plugin-pnpm": "catalog:lint",
		"eslint-plugin-react-hooks": "catalog:lint",
		"eslint-plugin-react-naming-convention": "catalog:lint",
		"eslint-plugin-react-x": "catalog:lint",
		"eslint_d": "catalog:lint",
		"file-entry-cache": "catalog:lint",
		"get-tsconfig": "catalog:lint",
		"jiti": "catalog:script",
		"madge": "catalog:lint",
		"pncat": "catalog:cli",
		"rbxts-transformer-jest": "catalog:test",
		"rimraf": "catalog:node",
		"turbo": "catalog:build",
		"type-fest": "catalog:types",
		"typescript": "catalog:tsc"
	},
	"packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
