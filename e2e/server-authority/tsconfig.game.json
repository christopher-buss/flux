{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"tsBuildInfoFile": "out/tsconfig.tsbuildinfo",
		"rootDir": "src",
		"customConditions": ["source"],
		"paths": {
			"shared/*": ["./src/shared/*"]
		},
		"typeRoots": ["./node_modules/@rbxts", "./node_modules/@flux"],
		"types": ["compiler-types"],
		"outDir": "out"
	},
	"include": ["src/**/*.ts", "../../types/**/*.d.ts"]
}
