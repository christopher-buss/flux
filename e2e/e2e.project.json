{
	"name": "flux-e2e",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"client": {
				"$path": "out/client"
			},
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@flux": {
						"$className": "Folder",
						"$path": "node_modules/@flux"
					},
					"@rbxts": {
						"$className": "Folder",
						"$path": "../rojo-sync/@rbxts"
					},
					"@rbxts-js": {
						"$className": "Folder",
						"$path": "../rojo-sync/@rbxts-js"
					}
				}
			},
			"shared": {
				"$path": "out/shared"
			}
		},
		"Workspace": {
			"$className": "Workspace",
			"$path": "assets/models/workspace",
			"$properties": {
				"FilteringEnabled": true,
				"SignalBehavior": "Deferred"
			},
			"Baseplate": {
				"$className": "Part",
				"$properties": {
					"Anchored": true,
					"Color": [0.38823, 0.37254, 0.38823],
					"Locked": true,
					"Position": [0, -10, 0],
					"Size": [50, 2, 50]
				}
			}
		}
	}
}
