{
	"name": "flux-e2e-jecs",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"client": {
				"$path": "out/client"
			},
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@rbxts": {
						"$className": "Folder",
						"$path": "../../rojo-sync/@rbxts",
						"flux": {
							"$path": "node_modules/@rbxts/flux"
						},
						"flux-jecs": {
							"$path": "node_modules/@rbxts/flux-jecs"
						}
					},
					"@rbxts-js": {
						"$className": "Folder",
						"$path": "../../rojo-sync/@rbxts-js"
					}
				}
			},
			"shared": {
				"$path": "out/shared"
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"server": {
				"$path": "out/server"
			}
		},
		"Workspace": {
			"$className": "Workspace",
			"$properties": {
				"FilteringEnabled": true,
				"SignalBehavior": "Deferred"
			},
			"Baseplate": {
				"$className": "Part",
				"$properties": {
					"Anchored": true,
					"Color": [0.38823, 0.37254, 0.38823],
					"Locked": true,
					"Position": [0, -10, 0],
					"Size": [50, 2, 50]
				}
			}
		}
	}
}
