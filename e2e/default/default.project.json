{
	"name": "flux-e2e-default",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"client": {
				"$path": "out/client"
			},
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@flux": {
						"$className": "Folder",
						"$path": "node_modules/@flux"
					},
					"@rbxts": {
						"$className": "Folder",
						"$path": "../../rojo-sync/@rbxts"
					},
					"@rbxts-js": {
						"$className": "Folder",
						"$path": "../../rojo-sync/@rbxts-js"
					}
				}
			},
			"shared": {
				"$path": "out/shared"
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"server": {
				"$path": "out/server"
			}
		},
		"Workspace": {
			"$className": "Workspace",
			"$properties": {
				"FilteringEnabled": true,
				"SignalBehavior": "Deferred"
			},
			"Baseplate": {
				"$className": "Part",
				"$properties": {
					"Anchored": true,
					"Color": [0.38823, 0.37254, 0.38823],
					"Locked": true,
					"Position": [0, -10, 0],
					"Size": [50, 2, 50]
				}
			},
			"Interactable": {
				"$className": "Part",
				"$properties": {
					"Anchored": true,
					"Color": [0.0, 0.6, 1.0],
					"Material": "Neon",
					"Name": "Interactable",
					"Position": [5, -7, 5],
					"Shape": "Cylinder",
					"Size": [3, 2, 2]
				}
			}
		}
	}
}
